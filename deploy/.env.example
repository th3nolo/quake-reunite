# Copy to .env on the VPS. NEVER commit the filled-in file.

# Cerebras Gemma-4 (text + vision + agent).
CEREBRAS_API_KEY=csk-your-key-here
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_API_URL=https://api.cerebras.ai/v1/chat/completions

# Mistral OCR (documents/photos -> markdown)
OCR_API_KEY=...
OCR_API_URL=https://api.mistral.ai/v1/ocr
OCR_MODEL=mistral-ocr-latest

# Firecrawl (Gemma-driven scraping/interact of JS + closed sites: center refresh,
# cédula CNE, federated sources, agent tools). Without these the firecrawl calls
# degrade to a plain GET that can't render JS pages.
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_API_URL=https://api.firecrawl.dev

# Runtime
DATA_DIR=/data
API_RATE_PER_MIN=120
API_RELOAD_URL=http://api:8080/admin/reload
# MAINTAINER_GEMMA_PRIORITIZE=1   # let Gemma order the due-source list each cycle
